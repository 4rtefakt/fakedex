# Cloudflare Pages headers.
# Vendored libs never change — cache hard.
/vendor/*
  Cache-Control: public, max-age=31536000, immutable
# The big base asset bundle is versioned in its filename; safe to cache hard.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
# Generated data files are regenerated in place, so they must revalidate
# (a conditional request → 304 when unchanged, so no re-download).
/data/*
  Cache-Control: public, max-age=0, must-revalidate

# App code — revalidate so updates ship immediately.
/js/*
  Cache-Control: public, max-age=0, must-revalidate
/styles.css
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
